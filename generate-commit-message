#!/usr/bin/env bash
#
# generate-commit-message - Generate a one-line imperative commit message for
#                           staged files using a local Ollama model, then
#                           optionally commit.

set -euo pipefail

GREEN='\033[32m'
RED='\033[31m'
ORANGE='\033[38;5;208m'
RESET='\033[0m'

# Ollama model to use. Override with the OLLAMA_MODEL environment variable.
OLLAMA_MODEL="${OLLAMA_MODEL:-qwen2.5-coder:7b}"

force=false
for arg in "$@"; do
	case "$arg" in
		-f) force=true ;;
		--help)
			echo "Usage: generate-commit-message [-f]"
			echo ""
			echo "Generate a commit message for staged changes using a local Ollama model."
			echo ""
			echo "Options:"
			echo "  -f        Commit immediately without confirmation prompt"
			echo "  --help    Show this help message"
			echo ""
			echo "Environment:"
			echo "  OLLAMA_MODEL    Ollama model to use (default: qwen2.5-coder:7b)"
			exit 0
			;;
		*) echo -e "${RED}Unknown option: $arg${RESET}" >&2; exit 1 ;;
	esac
done

# Ensure we are inside a git repository
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
	echo -e "${RED}Error: not inside a git repository.${RESET}" >&2
	exit 1
fi

# Ensure there are staged files
if git diff --cached --quiet; then
	echo -e "${RED}Error: no staged files. Stage changes with 'git add' first.${RESET}" >&2
	exit 1
fi

# Ensure the ollama CLI is available
if ! command -v ollama >/dev/null 2>&1; then
	echo -e "${RED}Error: 'ollama' not found on PATH. Install it from https://ollama.com${RESET}" >&2
	exit 1
fi

# Announce what we're about to do.
echo "Generating using ${OLLAMA_MODEL}"

# Ensure the Ollama server is reachable; start it in the background if not.
# Ollama unloads idle models on its own (keep_alive), so we don't stop it here.
if ! curl -fsS http://localhost:11434/api/version >/dev/null 2>&1; then
	echo -e "${ORANGE}Loading ollama...${RESET}"
	ollama serve >/dev/null 2>&1 &
	for _ in $(seq 1 25); do
		curl -fsS http://localhost:11434/api/version >/dev/null 2>&1 && break
		sleep 0.2
	done
	if ! curl -fsS http://localhost:11434/api/version >/dev/null 2>&1; then
		echo -e "${RED}Error: could not start the Ollama server.${RESET}" >&2
		exit 1
	fi
fi

# Collect the staged diff, excluding noisy/generated files. The --stat summary
# gives the model the overall shape of the change even when the diff is large.
diff=$(git diff --cached -- . ':!*.lock' ':!*.lockb' ':!package-lock.json' ':!yarn.lock')
stat=$(git diff --cached --stat -- . ':!*.lock' ':!*.lockb' ':!package-lock.json' ':!yarn.lock')

# Keep the diff within the model's context window. A truncated-but-complete
# prompt produces a far better message than one that silently overflows.
max_chars="${GITMSG_MAX_DIFF_CHARS:-12000}"
if [ "${#diff}" -gt "$max_chars" ]; then
	diff="${diff:0:$max_chars}

[diff truncated — see the file summary above for the full scope of changes]"
fi

# A focused system role plus explicit rules and examples steer small local
# models much more reliably than a single terse instruction.
system="You are a senior software engineer writing git commit messages. You produce one concise, accurate, imperative-mood subject line that captures the intent of a change, not a file-by-file listing."

prompt="Write a single-line git commit message for the staged changes below.

Rules:
- Output exactly one line: the subject. No body, no quotes, no markdown, no prefix like 'Commit message:'.
- Use the imperative mood: 'Add', 'Fix', 'Refactor', 'Remove' — never past tense.
- Keep it under ~72 characters.
- Capitalize the first word; no trailing period.
- Summarize the overall intent and the 'why' where clear, not every edited line.
- Be specific: name the feature, component, or bug, not vague words like 'update code'.

Examples of good messages:
- Add retry with backoff to the upload client
- Fix off-by-one error in pagination offset
- Remove unused legacy auth middleware

Files changed:
$stat

Diff:
$diff"

# Generate a commit message into the global $gitmessage. Takes a temperature so
# the first pass can be deterministic while regenerations explore alternatives.
# Calls the generate API directly (instead of 'ollama run') so we can set a
# system role, the temperature, a random seed, and a larger context window than
# the 2048-token default that would otherwise truncate real diffs.
generate_message() {
	local temperature="$1"
	local payload response apierror raw line

	payload=$(jq -n \
		--arg model "$OLLAMA_MODEL" \
		--arg system "$system" \
		--arg prompt "$prompt" \
		--argjson temperature "$temperature" \
		--argjson seed "$RANDOM" \
		'{model: $model, system: $system, prompt: $prompt, stream: false,
		  options: {temperature: $temperature, top_p: 0.9, num_ctx: 8192, seed: $seed}}')

	# Don't use curl's -f here: on errors (e.g. an un-pulled model returns 404)
	# we still want the response body so we can show Ollama's own error message.
	response=$(curl -sS http://localhost:11434/api/generate -d "$payload" 2>/dev/null || true)

	# Surface a clear, actionable message when the model isn't installed.
	apierror=$(printf '%s' "$response" | jq -r '.error // empty' 2>/dev/null || true)
	if [ -n "$apierror" ]; then
		echo -e "${RED}Error from Ollama: ${apierror}${RESET}" >&2
		if printf '%s' "$apierror" | grep -qi 'not found'; then
			echo -e "${ORANGE}Pull it first: ollama pull ${OLLAMA_MODEL}${RESET}" >&2
		fi
		exit 1
	fi

	raw=$(printf '%s' "$response" | jq -r '.response // empty' 2>/dev/null || true)

	# Take the first non-blank line, then strip wrapping quotes/backticks and any
	# trailing period the model may have added despite the instructions.
	gitmessage=""
	while IFS= read -r line; do
		if [ -n "${line//[[:space:]]/}" ]; then
			gitmessage=$line
			break
		fi
	done <<< "$raw"

	gitmessage="${gitmessage#"${gitmessage%%[![:space:]]*}"}"   # trim leading space
	gitmessage="${gitmessage%"${gitmessage##*[![:space:]]}"}"   # trim trailing space
	gitmessage="${gitmessage#[\"\`\']}"                          # strip leading quote
	gitmessage="${gitmessage%[\"\`\']}"                          # strip trailing quote
	gitmessage="${gitmessage%.}"                                 # strip trailing period

	if [ -z "$gitmessage" ]; then
		echo -e "${RED}Error: failed to generate a commit message (model: $OLLAMA_MODEL).${RESET}" >&2
		exit 1
	fi
}

# First pass: low temperature for an accurate, focused message.
generate_message 0.2
echo -e "${GREEN}${gitmessage}${RESET}"

if $force; then
	git commit -m "$gitmessage"
	exit 0
fi

# Confirmation loop. Pressing space regenerates a fresh suggestion (with more
# variability) without leaving the prompt; the keypress is read a single
# character at a time so space alone triggers it.
while true; do
	printf "Commit? [Y]es / [n]o / [e]dit / [space] regenerate "
	IFS= read -rsn1 reply
	echo
	case "$reply" in
		"" | [yY])
			git commit -m "$gitmessage"
			break
			;;
		" ")
			echo -e "${ORANGE}Regenerating...${RESET}"
			generate_message 0.6
			echo -e "${GREEN}${gitmessage}${RESET}"
			;;
		[eE])
			# Let the user edit the generated message, then commit with the result.
			read -r -e -i "$gitmessage" -p "Edit message: " edited
			edited=${edited:-$gitmessage}
			if [ -z "${edited//[[:space:]]/}" ]; then
				echo "Aborted: empty commit message."
			else
				git commit -m "$edited"
			fi
			break
			;;
		*)
			echo "Aborted."
			break
			;;
	esac
done
